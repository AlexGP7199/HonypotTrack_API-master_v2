{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Security": {
    "WhitelistedIps": [
      "127.0.0.1",
      "::1"
    ],
    "EnableBlocking": false,
    "Honeypot": {
      "EnableBehavioralDetection": true,
      "AllowWhitelistActivation": true,
      "IssueSessionOnAnyHighSeverityThreat": true,
      "FailedLoginThreshold": 3,
      "FailedLoginWindowMinutes": 10,
      "EnableTestHeaderInDevelopment": true,
      "TestHeaderName": "X-Test-Honeypot",
      "TestHeaderValue": "true",
      "EnableThreatSimulationInDevelopment": true,
      "ThreatSimulationHeaderName": "X-Simulate-Threat"
    }
  }
}
